let tasks = [];

// Add Task
function addTask() {
  let input = document.getElementById("taskInput");
  let text = input.value.trim();

  if (text === "") {
    alert("Please enter a task");
    return;
  }

  let task = {
    text: text,
    done: false,
    pinned: false,
  };

  tasks.push(task);

  input.value = "";

  displayTasks();
}

// Display Tasks
function displayTasks() {
  let list = document.getElementById("taskList");

  list.innerHTML = "";

  tasks.forEach((task, index) => {
    let li = document.createElement("li");

    if (task.done) {
      li.style.textDecoration = "line-through";
    }

    li.innerHTML = `
<span>${task.text}</span>

<button onclick="doneTask(${index})">✔ Done</button>
<button onclick="pinTask(${index})">📌 Pin</button>
<button onclick="deleteTask(${index})">🗑 Delete</button>
`;

    list.appendChild(li);
  });
}

// Done Task
function doneTask(index) {
  tasks[index].done = true;

  displayTasks();
}

// Pin Task
function pinTask(index) {
  tasks[index].pinned = !tasks[index].pinned;

  tasks.sort((a, b) => b.pinned - a.pinned);

  displayTasks();
}

// Delete Task
function deleteTask(index) {
  tasks.splice(index, 1);

  displayTasks();
}

// Search Task
function searchTask() {
  let input = document.getElementById("searchTask").value.toLowerCase();

  let items = document.querySelectorAll("#taskList li");

  items.forEach((item) => {
    let text = item.innerText.toLowerCase();

    if (text.includes(input)) {
      item.style.display = "";
    } else {
      item.style.display = "none";
    }
  });
}
